{
  "name": "@yadimon/claude-code-to-llm",
  "version": "0.3.5",
  "description": "Use Claude Code as a simple LLM provider through an SDK and CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yadimon/claude-code-to-llm.git"
  },
  "homepage": "https://github.com/yadimon/claude-code-to-llm#readme",
  "bugs": {
    "url": "https://github.com/yadimon/claude-code-to-llm/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "claude-code-to-llm": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "auth:copy": "tsx ./scripts/copy-auth.ts",
    "build": "node --input-type=module --eval \"import fs from 'node:fs'; for (const target of ['dist', '.tsbuildinfo']) { fs.rmSync(target, { recursive: true, force: true, maxRetries: 10, retryDelay: 50 }); }\" && tsc -b tsconfig.json",
    "e2e": "tsx ./scripts/e2e-cli.ts",
    "lint": "eslint src test scripts",
    "pack": "npm pack --dry-run",
    "pack:check": "npm run pack && publint",
    "publish:dry-run": "npm publish --dry-run",
    "release:check": "tsx ./scripts/release-check.ts",
    "smoke:cli": "tsx ./src/cli.ts --prompt \"Hi\" --json --model claude-sonnet-4-6",
    "smoke:sdk": "tsx ./scripts/smoke-sdk.ts",
    "smoke:search": "tsx ./scripts/smoke-search.ts",
    "prepack": "npm run test && npm run build",
    "test": "tsx ./scripts/run-node-tests.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "claude",
    "claude-code",
    "llm",
    "cli",
    "sdk",
    "openai"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
