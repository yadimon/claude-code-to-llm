{
  "name": "claude-code-to-llm-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start:server": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server start",
    "start:server:mock": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server start:mock",
    "build": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm build && tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build",
    "pack": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm pack && tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server pack",
    "publish:dry-run": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm publish:dry-run && tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server publish:dry-run",
    "check": "npm run verify && npm run pack && npm run publish:dry-run",
    "release:check": "tsx ./scripts/workspace-release-check.ts",
    "release:core:patch": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm patch claude-code-to-llm",
    "release:core:minor": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm minor claude-code-to-llm",
    "release:core:major": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm major claude-code-to-llm",
    "release:server:patch": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm-server patch claude-code-to-llm-server",
    "release:server:minor": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm-server minor claude-code-to-llm-server",
    "release:server:major": "tsx ./scripts/release-workspace.ts @yadimon/claude-code-to-llm-server major claude-code-to-llm-server",
    "test": "tsx ./scripts/run-root-node-tests.ts && tsx ./scripts/run-workspace-tests.ts",
    "test:docker": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server test:docker",
    "test:all": "tsx ./scripts/run-workspace-tests.ts && tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server test:docker",
    "smoke:core": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm smoke:sdk",
    "smoke:tokens": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm smoke:tokens",
    "smoke:server": "tsx ./scripts/run-npm-workspace.ts @yadimon/claude-code-to-llm-server smoke",
    "smoke:published-core": "node ./scripts/smoke-published.mjs core",
    "smoke:published-server": "node ./scripts/smoke-published.mjs server",
    "smoke:published": "node ./scripts/smoke-published.mjs all"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "publint": "^0.3.21",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
